{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:watch": "nodemon server.js",
    "electron": "electron .",
    "electron:dev": "set ELECTRON_START_URL=http://localhost:3000&& electron .",
    "build:frontend": "npm --prefix ../frontend run build",
    "build-electron": "npm run build:frontend && electron-builder --win nsis --publish=never",
    "dist": "npm run build:frontend && electron-builder --win nsis --publish=never"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "main": "main.js",
  "homepage": "./",
  "build": {
    "appId": "com.autoappgenerator.electron",
    "productName": "Auto App Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "server.js",
      "routes/**/*",
      "services/**/*",
      "utils/**/*",
      "models/**/*",
      "middleware/**/*",
      "controllers/**/*",
      "generated_projects/**/*",
      "preview_projects/**/*",
      "uploads/**/*",
      ".env",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../frontend/build",
        "to": "frontend-build"
      }
    ],
    "win": {
      "target": "nsis",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "ajv": "^8.17.1",
    "archiver": "^7.0.1",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "body-parser": "^2.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.1.0",
    "fs-extra": "^11.3.2",
    "jsonrepair": "^3.13.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "multer": "^2.0.2",
    "mysql2": "^3.15.2",
    "openai": "^6.3.0",
    "path": "^0.12.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  }
}
